<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Avatar -->
        <ImageView
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:background="@drawable/bg_circle_black"
            android:src="@android:drawable/ic_menu_my_calendar"
            android:tint="@color/white"
            android:padding="16dp"
            android:layout_marginTop="16dp" />

        <!-- Username -->
        <EditText
            android:id="@+id/et_username"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_pill_outline"
            android:hint="Your Name"
            android:hintTextColor="@color/white_70"
            android:textColor="@color/white"
            android:gravity="center"
            android:inputType="textPersonName" />

        <!-- User ID (read-only) -->
        <TextView
            android:id="@+id/tv_user_id"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_pill_outline"
            android:gravity="center"
            android:text="User ID: loading…"
            android:textColor="@color/white_70"
            android:textSize="13sp" />

        <!-- My Language -->
        <TextView
            android:id="@+id/tv_my_language"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_pill_outline"
            android:gravity="center"
            android:text="My Language: Bengali"
            android:textColor="@color/white"
            android:clickable="true"
            android:focusable="true" />

        <!-- Server URL -->
        <EditText
            android:id="@+id/et_server_url"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_pill_outline"
            android:hint="Server URL (ws://yourserver:8000)"
            android:hintTextColor="@color/white_70"
            android:textColor="@color/white"
            android:gravity="center"
            android:inputType="textUri" />

        <!-- Save Button -->
        <Button
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_pill_magenta"
            android:text="@string/save"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="16sp" />

    </LinearLayout>
</ScrollView>

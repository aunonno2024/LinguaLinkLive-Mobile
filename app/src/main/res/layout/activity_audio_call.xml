<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/navy_dark">

    <!-- World Map Background -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/ic_world_map"
        android:scaleType="centerCrop"
        android:alpha="0.15"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Logo -->
    <LinearLayout
        android:id="@+id/ll_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@mipmap/ic_launcher"
            android:scaleType="fitCenter" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lingua\nLink Live"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/powered_by"
                android:textColor="@color/white_70"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- Phone Number / Caller Name -->
    <TextView
        android:id="@+id/tv_caller_number"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_pill_magenta"
        android:gravity="center"
        android:text="654-321-687-82"
        android:textColor="@color/white"
        android:textSize="18sp"
        app:layout_constraintTop_toBottomOf="@id/ll_header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Avatar -->
    <ImageView
        android:id="@+id/iv_avatar"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:background="@drawable/bg_circle_black"
        android:src="@android:drawable/ic_menu_my_calendar"
        android:tint="@color/white_70"
        android:padding="20dp"
        app:layout_constraintTop_toBottomOf="@id/tv_caller_number"
        app:layout_constraintBottom_toTopOf="@id/tv_call_status"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.4" />

    <!-- Call Status -->
    <TextView
        android:id="@+id/tv_call_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Calling app interface"
        android:textColor="@color/white_70"
        android:textSize="12sp"
        app:layout_constraintBottom_toTopOf="@id/ll_call_controls"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="12dp" />

    <!-- Translation Status -->
    <TextView
        android:id="@+id/tv_translation_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="@color/teal_accent"
        android:textSize="11sp"
        app:layout_constraintBottom_toTopOf="@id/tv_call_status"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="4dp" />

    <!-- Call Controls Row -->
    <LinearLayout
        android:id="@+id/ll_call_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingHorizontal="8dp"
        app:layout_constraintBottom_toTopOf="@id/bottom_bar"
        android:layout_marginBottom="20dp">

        <!-- Speaker -->
        <ImageView
            android:id="@+id/btn_speaker"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_circle_black"
            android:src="@android:drawable/ic_lock_silent_mode_off"
            android:tint="@color/white"
            android:padding="10dp"
            android:layout_margin="6dp"
            android:clickable="true"
            android:focusable="true" />

        <!-- Mute Mic -->
        <ImageView
            android:id="@+id/btn_mute"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_circle_black"
            android:src="@android:drawable/ic_btn_speak_now"
            android:tint="@color/white"
            android:padding="10dp"
            android:layout_margin="6dp"
            android:clickable="true"
            android:focusable="true" />

        <!-- Mute Translation -->
        <ImageView
            android:id="@+id/btn_mute_translation"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_circle_black"
            android:src="@android:drawable/ic_btn_speak_now"
            android:tint="@color/white_70"
            android:padding="10dp"
            android:layout_margin="6dp"
            android:clickable="true"
            android:focusable="true" />

        <!-- Video Toggle -->
        <ImageView
            android:id="@+id/btn_video"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_circle_black"
            android:src="@android:drawable/ic_menu_camera"
            android:tint="@color/white"
            android:padding="10dp"
            android:layout_margin="6dp"
            android:clickable="true"
            android:focusable="true" />

        <!-- Camera Off -->
        <ImageView
            android:id="@+id/btn_camera_off"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_circle_black"
            android:src="@android:drawable/ic_menu_camera"
            android:tint="@color/white_70"
            android:padding="10dp"
            android:layout_margin="6dp"
            android:clickable="true"
            android:focusable="true" />

        <!-- More Options -->
        <ImageView
            android:id="@+id/btn_more"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_circle_black"
            android:src="@android:drawable/ic_menu_more"
            android:tint="@color/white"
            android:padding="10dp"
            android:layout_margin="6dp"
            android:clickable="true"
            android:focusable="true" />

        <!-- End Call -->
        <ImageView
            android:id="@+id/btn_end_call"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_circle_black"
            android:backgroundTint="@color/call_red"
            android:src="@android:drawable/stat_sys_phone_call_on_hold"
            android:tint="@color/white"
            android:padding="10dp"
            android:layout_margin="6dp"
            android:clickable="true"
            android:focusable="true" />

        <!-- Accept Call -->
        <ImageView
            android:id="@+id/btn_accept_call"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_circle_black"
            android:backgroundTint="@color/call_green"
            android:src="@android:drawable/stat_sys_phone_call"
            android:tint="@color/white"
            android:padding="10dp"
            android:layout_margin="6dp"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <!-- Bottom Bar (same as main) -->
    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:orientation="horizontal"
        android:background="@drawable/bg_bottom_nav"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView android:layout_width="0dp" android:layout_height="32dp"
            android:layout_weight="1" android:src="@android:drawable/ic_menu_call"
            android:tint="@color/white" android:scaleType="centerInside" />
        <ImageView android:layout_width="0dp" android:layout_height="32dp"
            android:layout_weight="1" android:src="@android:drawable/ic_dialog_email"
            android:tint="@color/teal_accent" android:scaleType="centerInside" />
        <ImageView android:layout_width="0dp" android:layout_height="32dp"
            android:layout_weight="1" android:src="@android:drawable/ic_menu_my_calendar"
            android:tint="@color/white" android:scaleType="centerInside" />
        <ImageView android:layout_width="0dp" android:layout_height="32dp"
            android:layout_weight="1" android:src="@android:drawable/ic_menu_camera"
            android:tint="@color/white" android:scaleType="centerInside" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

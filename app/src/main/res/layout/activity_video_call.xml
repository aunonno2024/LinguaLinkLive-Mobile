<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <!-- Remote Video (full screen) -->
    <org.webrtc.SurfaceViewRenderer
        android:id="@+id/sv_remote_video"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Local Video (PIP) -->
    <org.webrtc.SurfaceViewRenderer
        android:id="@+id/sv_local_video"
        android:layout_width="100dp"
        android:layout_height="140dp"
        android:layout_margin="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Translation Overlay -->
    <TextView
        android:id="@+id/tv_translation_overlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxWidth="280dp"
        android:background="@drawable/bg_pill_magenta"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:visibility="gone"
        android:layout_marginBottom="100dp"
        app:layout_constraintBottom_toTopOf="@id/ll_video_controls"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Controls -->
    <LinearLayout
        android:id="@+id/ll_video_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingBottom="40dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:id="@+id/btn_mute_video"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/bg_circle_black"
            android:src="@android:drawable/ic_btn_speak_now"
            android:tint="@color/white"
            android:padding="12dp"
            android:layout_margin="8dp"
            android:clickable="true"
            android:focusable="true" />

        <ImageView
            android:id="@+id/btn_camera_toggle"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/bg_circle_black"
            android:src="@android:drawable/ic_menu_camera"
            android:tint="@color/white"
            android:padding="12dp"
            android:layout_margin="8dp"
            android:clickable="true"
            android:focusable="true" />

        <ImageView
            android:id="@+id/btn_end_video_call"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/bg_circle_black"
            android:backgroundTint="@color/call_red"
            android:src="@android:drawable/stat_sys_phone_call_on_hold"
            android:tint="@color/white"
            android:padding="14dp"
            android:layout_margin="8dp"
            android:clickable="true"
            android:focusable="true" />

        <ImageView
            android:id="@+id/btn_flip_camera"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/bg_circle_black"
            android:src="@android:drawable/ic_menu_rotate"
            android:tint="@color/white"
            android:padding="12dp"
            android:layout_margin="8dp"
            android:clickable="true"
            android:focusable="true" />

        <ImageView
            android:id="@+id/btn_speaker_video"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/bg_circle_black"
            android:src="@android:drawable/ic_lock_silent_mode_off"
            android:tint="@color/white"
            android:padding="12dp"
            android:layout_margin="8dp"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
